<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.SplashPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1a1a2e">

    <!-- Anillos decorativos de fondo -->
    <AbsoluteLayout>

        <!-- Anillo exterior -->
        <Ellipse AbsoluteLayout.LayoutBounds="0.5, 0.42, 320, 320"
                 AbsoluteLayout.LayoutFlags="PositionProportional"
                 Stroke="#1a4e3a"
                 StrokeThickness="1"
                 Fill="Transparent"/>

        <!-- Anillo interior -->
        <Ellipse AbsoluteLayout.LayoutBounds="0.5, 0.42, 220, 220"
                 AbsoluteLayout.LayoutFlags="PositionProportional"
                 Stroke="#1e3d2f"
                 StrokeThickness="1"
                 Fill="Transparent"/>

        <!-- Contenido principal centrado -->
        <VerticalStackLayout AbsoluteLayout.LayoutBounds="0.5, 0.5, 1, AutoSize"
                             AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional"
                             HorizontalOptions="Center"
                             Spacing="12"
                             Padding="40,0">

            <!-- Ícono -->
            <Border BackgroundColor="#1e4d36"
                    StrokeThickness="1"
                    Stroke="#4ecb8d"
                    HorizontalOptions="Center"
                    WidthRequest="80"
                    HeightRequest="80">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22"/>
                </Border.StrokeShape>
                <Label Text="🌿"
                       FontSize="38"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Nombre de la app -->
            <Label Text="Hábitos"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   Margin="0,8,0,-10"/>
            <Label Text="Saludables"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="#4ecb8d"
                   HorizontalTextAlignment="Center"/>

            <!-- Tagline -->
            <Label Text="TU BIENESTAR DIARIO"
                   FontSize="11"
                   TextColor="#4a6658"
                   CharacterSpacing="3"
                   HorizontalTextAlignment="Center"
                   Margin="0,6,0,0"/>

        </VerticalStackLayout>

        <!-- Indicadores de puntos en la parte inferior -->
        <HorizontalStackLayout AbsoluteLayout.LayoutBounds="0.5, 0.88, AutoSize, AutoSize"
                               AbsoluteLayout.LayoutFlags="PositionProportional"
                               Spacing="8">
            <!-- Punto activo (más largo) -->
            <BoxView BackgroundColor="#4ecb8d"
                     WidthRequest="20"
                     HeightRequest="6"
                     CornerRadius="3"
                     VerticalOptions="Center"/>
            <BoxView BackgroundColor="#2a3d35"
                     WidthRequest="6"
                     HeightRequest="6"
                     CornerRadius="3"
                     VerticalOptions="Center"/>
            <BoxView BackgroundColor="#2a3d35"
                     WidthRequest="6"
                     HeightRequest="6"
                     CornerRadius="3"
                     VerticalOptions="Center"/>
        </HorizontalStackLayout>

    </AbsoluteLayout>
</ContentPage>
