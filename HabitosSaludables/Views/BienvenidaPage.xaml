<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.BienvenidaPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <Grid RowDefinitions="200,*">

        <!-- Hero superior oscuro -->
        <Grid Grid.Row="0" BackgroundColor="#1a1a2e">

            <!-- Círculo decorativo de fondo -->
            <Ellipse HorizontalOptions="End"
                     VerticalOptions="Start"
                     WidthRequest="160"
                     HeightRequest="160"
                     Fill="#0d2e22"
                     Margin="0,-40,-30,0"/>

            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="10"
                                 Padding="24">

                <!-- Ícono con borde verde -->
                <Border BackgroundColor="#172e22"
                        StrokeThickness="1"
                        Stroke="#2e6b4f"
                        HorizontalOptions="Center"
                        WidthRequest="56"
                        HeightRequest="56">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Label Text="🌿"
                           FontSize="26"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Label Text="Bienvenido"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>

                <Label Text="empieza tu camino hoy"
                       FontSize="12"
                       TextColor="#4ecb8d"
                       CharacterSpacing="1"
                       HorizontalTextAlignment="Center"/>

            </VerticalStackLayout>
        </Grid>

        <!-- Cuerpo inferior blanco -->
        <VerticalStackLayout Grid.Row="1"
                             Padding="28,36,28,28"
                             Spacing="14"
                             VerticalOptions="Start">

            <Label Text="¿Qué deseas hacer?"
                   FontSize="13"
                   TextColor="#b0a99e"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,4"/>

            <!-- Botón primario -->
            <Button Text="Registrarse"
                    x:Name="RegistroBtn"
                    Clicked="OnRegisterClicked"
                    BackgroundColor="#1a1a2e"
                    TextColor="White"
                    FontSize="15"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    HeightRequest="52"
                    Shadow="{Shadow Brush=#1a1a2e, Offset='0,4', Radius=12, Opacity=0.25}"/>

            <!-- Botón outline -->
            <Border BackgroundColor="Transparent"
                    StrokeThickness="1.5"
                    Stroke="#e0ddd8"
                    HeightRequest="52">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Button Text="Iniciar Sesión"
                        x:Name="LoginBtn"
                        Clicked="OnLoginClicked"
                        BackgroundColor="Transparent"
                        TextColor="#1a1a2e"
                        FontSize="15"
                        FontAttributes="Bold"/>
            </Border>

            <!-- Separador sutil -->
            <HorizontalStackLayout HorizontalOptions="Center"
                                   Spacing="10"
                                   Margin="0,8,0,0">
                <BoxView BackgroundColor="#e8e5e0"
                         HeightRequest="1"
                         WidthRequest="60"
                         VerticalOptions="Center"/>
                <Label Text="o continúa con"
                       FontSize="12"
                       TextColor="#c0bab2"
                       VerticalOptions="Center"/>
                <BoxView BackgroundColor="#e8e5e0"
                         HeightRequest="1"
                         WidthRequest="60"
                         VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Versión -->
            <Label Text="v1.0.0"
                   FontSize="11"
                   TextColor="#d0cbc4"
                   HorizontalTextAlignment="Center"
                   Margin="0,16,0,0"/>

        </VerticalStackLayout>

    </Grid>
</ContentPage>
