<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:HabitosSaludables.ViewModels"
             x:Class="HabitosSaludables.Views.MisHabitosPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f0f6ff">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0a1f3d" Offset="0.0"/>
                    <GradientStop Color="#1a3f7a" Offset="0.6"/>
                    <GradientStop Color="#0f2a54" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse HorizontalOptions="End" VerticalOptions="Start"
                     WidthRequest="140" HeightRequest="140"
                     Margin="0,-30,-20,0" Opacity="0.4">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#2e6abf" Offset="0.0"/>
                        <GradientStop Color="#1a3f7a" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse HorizontalOptions="Start" VerticalOptions="End"
                     WidthRequest="75" HeightRequest="75"
                     Opacity="0.25" Margin="30,0,0,-5">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4a9eff" Offset="0.0"/>
                        <GradientStop Color="#1a3f7a" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Grid Padding="22,52,22,24" ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="MI COLECCIÓN"
                           FontSize="9" TextColor="#4a9eff"
                           CharacterSpacing="2.2" FontAttributes="Bold"/>
                    <Label Text="Mis Hábitos"
                           FontSize="26" FontAttributes="Bold" TextColor="#ffffff"
                           CharacterSpacing="-0.3"/>
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        StrokeThickness="0"
                        VerticalOptions="Center" Padding="16,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#2e6aef" Offset="0.0"/>
                            <GradientStop Color="#4a9eff" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label Text="+ Nuevo" FontSize="12" FontAttributes="Bold" TextColor="#ffffff"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AgregarNuevoHabitoCommand}"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </Grid>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}"
                     Command="{Binding LoadHabitosCommand}"
                     BackgroundColor="#f0f6ff">
            <CollectionView ItemsSource="{Binding Habitos}" BackgroundColor="Transparent">
                <CollectionView.Header>
                    <BoxView HeightRequest="14" BackgroundColor="Transparent"/>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="18,0,18,10"
                                BackgroundColor="#ffffff"
                                StrokeThickness="1.5" Stroke="#c8d8f8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Grid Padding="14,14" ColumnDefinitions="46,*,36,36" ColumnSpacing="4">

                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        WidthRequest="38" HeightRequest="38" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="11"/>
                                    </Border.StrokeShape>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#dce8ff" Offset="0.0"/>
                                            <GradientStop Color="#c8d8ff" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Label Text="{Binding Icono}" FontSize="20"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     VerticalOptions="Center" Spacing="3" Margin="10,0">
                                    <Label Text="{Binding Nombre}"
                                           FontSize="14" FontAttributes="Bold" TextColor="#0a1f3d"/>
                                    <HorizontalStackLayout Spacing="6">
                                        <Border StrokeThickness="0" Padding="6,2">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6"/>
                                            </Border.StrokeShape>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#dce8ff" Offset="0.0"/>
                                                    <GradientStop Color="#c8d8ff" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Label Text="{Binding Categoria}" FontSize="9" TextColor="#2a5aaa"/>
                                        </Border>
                                        <Label Text="{Binding RachaActual, StringFormat='&#128293; {0} días'}"
                                               FontSize="10" TextColor="#7a9abe" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <Border Grid.Column="2"
                                        BackgroundColor="{Binding CompletadoHoy, Converter={StaticResource BoolToColorConverter}}"
                                        StrokeThickness="1.5" Stroke="#a8c4e8"
                                        WidthRequest="34" HeightRequest="34" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Button BackgroundColor="Transparent"
                                            TextColor="{Binding CompletadoHoy, Converter={StaticResource BoolToCheckColorConverter}}"
                                            FontSize="14" FontAttributes="Bold" Text="&#10003;"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MisHabitosViewModel}}, Path=ToggleCompletadoCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding CompletadoHoy, Converter={StaticResource InverseBoolConverter}}"
                                            Padding="0" WidthRequest="34" HeightRequest="34"/>
                                </Border>

                                <Button Grid.Column="3"
                                        Text="&#128465;"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MisHabitosViewModel}}, Path=EliminarHabitoCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent"
                                        TextColor="#a8c4e8" FontSize="15"
                                        WidthRequest="34" HeightRequest="34"
                                        Padding="0" VerticalOptions="Center"/>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
