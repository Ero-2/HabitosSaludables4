<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f0f6ff">

    <Grid RowDefinitions="Auto,*">

        <!-- Header con degradado azul -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0a1f3d" Offset="0.0"/>
                    <GradientStop Color="#1a3f7a" Offset="0.5"/>
                    <GradientStop Color="#0f2a54" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse HorizontalOptions="End" VerticalOptions="Start"
                     WidthRequest="140" HeightRequest="140"
                     Margin="0,-30,-20,0" Opacity="0.5">
                <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1e4a8a" Offset="0.0"/>
                        <GradientStop Color="#2e6abf" Offset="1.0"/>
                    </LinearGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse HorizontalOptions="End" VerticalOptions="End"
                     WidthRequest="70" HeightRequest="70"
                     Opacity="0.3" Margin="0,0,40,10">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4a9eff" Offset="0.0"/>
                        <GradientStop Color="#2e6abf" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <VerticalStackLayout Padding="24,54,24,32" Spacing="8">

                <Border StrokeThickness="1" Stroke="#1e4a8a"
                        WidthRequest="36" HeightRequest="36"
                        HorizontalOptions="Start" Margin="0,0,0,12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0f2a54" Offset="0.0"/>
                            <GradientStop Color="#1a3f7a" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label Text="&#8249;" FontSize="20" TextColor="#4a9eff"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <HorizontalStackLayout Spacing="8" Margin="0,0,0,6">
                    <Label Text="💧" FontSize="18" VerticalOptions="Center"/>
                    <Label Text="Hábitos Saludables" FontSize="11"
                           TextColor="#4a9eff" FontAttributes="Bold" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Label Text="Bienvenido&#10;de vuelta"
                       FontSize="30" FontAttributes="Bold"
                       TextColor="#ffffff" LineHeight="1.15" CharacterSpacing="-0.3"/>

                <Label Text="Ingresa para continuar tu racha"
                       FontSize="12" TextColor="#4a6a9a"/>

            </VerticalStackLayout>
        </Grid>

        <!-- Formulario -->
        <ScrollView Grid.Row="1" BackgroundColor="#f0f6ff">
            <VerticalStackLayout Padding="24,28,24,40" Spacing="20">

                <VerticalStackLayout Spacing="8">
                    <Label Text="CORREO ELECTRÓNICO"
                           FontSize="10" TextColor="#7a9abe"
                           CharacterSpacing="1.8" FontAttributes="Bold"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#b8d0f0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry x:Name="emailEntry"
                               Placeholder="tu@correo.com" Keyboard="Email"
                               Text="{Binding Email}"
                               PlaceholderColor="#a8c4e8" TextColor="#0a1f3d"
                               FontSize="14" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="CONTRASEÑA"
                           FontSize="10" TextColor="#7a9abe"
                           CharacterSpacing="1.8" FontAttributes="Bold"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#b8d0f0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry x:Name="contrasenaEntry"
                               Placeholder="••••••••" IsPassword="True"
                               Text="{Binding Contrasena}"
                               PlaceholderColor="#a8c4e8" TextColor="#0a1f3d"
                               FontSize="14" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <Label Text="¿Olvidaste tu contraseña?"
                       FontSize="12" TextColor="#2a5aaa"
                       HorizontalTextAlignment="End" FontAttributes="Bold"/>

                <Border StrokeThickness="0" HeightRequest="56" Margin="0,6,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1a4abf" Offset="0.0"/>
                            <GradientStop Color="#2e6aef" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Button Text="Ingresar"
                            x:Name="LoginBtn"
                            Clicked="OnLoginClicked"
                            BackgroundColor="Transparent"
                            TextColor="#ffffff"
                            FontSize="15" FontAttributes="Bold"/>
                </Border>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="12" Margin="0,4">
                    <BoxView BackgroundColor="#b8d0f0" HeightRequest="1" WidthRequest="55" VerticalOptions="Center"/>
                    <Label Text="o" FontSize="12" TextColor="#8ab0d8" VerticalOptions="Center"/>
                    <BoxView BackgroundColor="#b8d0f0" HeightRequest="1" WidthRequest="55" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Label x:Name="RegistroBtn" FontSize="13" HorizontalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="¿No tienes cuenta? " TextColor="#7a9abe" FontSize="13"/>
                            <Span Text="Regístrate gratis" TextColor="#0a1f3d" FontSize="13" FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterClicked"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
