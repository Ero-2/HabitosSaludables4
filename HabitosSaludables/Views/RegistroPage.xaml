<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.RegistroPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

	<Grid RowDefinitions="160,*">

		<!-- Header con gradiente verde agua -->
		<Grid Grid.Row="0">
			<Grid.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#00c9a7" Offset="0.0"/>
					<GradientStop Color="#52d9a0" Offset="1.0"/>
				</LinearGradientBrush>
			</Grid.Background>

			<VerticalStackLayout VerticalOptions="End"
                                 Padding="24,0,24,32"
                                 Spacing="4">
				<Label Text="Crear cuenta"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>
				<Label Text="Es gratis y rápido"
                       FontSize="12"
                       TextColor="#b3f0de"
                       CharacterSpacing="1"
                       HorizontalTextAlignment="Center"/>
			</VerticalStackLayout>

			<!-- Curva inferior redondeada -->
			<BoxView BackgroundColor="White"
                     HeightRequest="30"
                     VerticalOptions="End"
                     CornerRadius="30,30,0,0"/>
		</Grid>

		<!-- Cuerpo del formulario -->
		<ScrollView Grid.Row="1">
			<VerticalStackLayout Padding="28,8,28,28"
                                 Spacing="14">

				<!-- Campo Nombre -->
				<VerticalStackLayout Spacing="6">
					<Label Text="NOMBRE COMPLETO"
                           FontSize="11"
                           TextColor="#b0a99e"
                           CharacterSpacing="1.5"
                           FontAttributes="Bold"/>
					<Border BackgroundColor="#f7f5f2"
                            StrokeThickness="0"
                            HeightRequest="50">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="12"/>
						</Border.StrokeShape>
						<Entry x:Name="nombreEntry"
                               Placeholder="Ej. Carlos García"
                               Text="{Binding Nombre}"
                               PlaceholderColor="#c8c2ba"
                               TextColor="#1a1a2e"
                               FontSize="14"
                               BackgroundColor="Transparent"
                               Margin="4,0"/>
					</Border>
				</VerticalStackLayout>

				<!-- Campo Correo -->
				<VerticalStackLayout Spacing="6">
					<Label Text="CORREO ELECTRÓNICO"
                           FontSize="11"
                           TextColor="#b0a99e"
                           CharacterSpacing="1.5"
                           FontAttributes="Bold"/>
					<Border BackgroundColor="#f7f5f2"
                            StrokeThickness="0"
                            HeightRequest="50">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="12"/>
						</Border.StrokeShape>
						<Entry x:Name="emailEntry"
                               Placeholder="tu@correo.com"
                               Keyboard="Email"
                               Text="{Binding Email}"
                               PlaceholderColor="#c8c2ba"
                               TextColor="#1a1a2e"
                               FontSize="14"
                               BackgroundColor="Transparent"
                               Margin="4,0"/>
					</Border>
				</VerticalStackLayout>

				<!-- Campo Contraseña -->
				<VerticalStackLayout Spacing="6">
					<Label Text="CONTRASEÑA"
                           FontSize="11"
                           TextColor="#b0a99e"
                           CharacterSpacing="1.5"
                           FontAttributes="Bold"/>
					<Border BackgroundColor="#f7f5f2"
                            StrokeThickness="0"
                            HeightRequest="50">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="12"/>
						</Border.StrokeShape>
						<Entry x:Name="contrasenaEntry"
                               Placeholder="Mínimo 8 caracteres"
                               IsPassword="True"
                               Text="{Binding Contrasena}"
                               PlaceholderColor="#c8c2ba"
                               TextColor="#1a1a2e"
                               FontSize="14"
                               BackgroundColor="Transparent"
                               Margin="4,0"/>
					</Border>
				</VerticalStackLayout>

				<!-- Botón Registrarse -->
				<Button Text="Registrarse"
                        x:Name="RegistrarBtn"
                        Clicked="OnRegisterClicked"
                        BackgroundColor="#00c9a7"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        HeightRequest="52"
                        Margin="0,8,0,0"
                        Shadow="{Shadow Brush=#00c9a7, Offset='0,4', Radius=14, Opacity=0.3}"/>

				<!-- Link login -->
				<Label x:Name="LoginBtn"
                       Text="¿Ya tienes cuenta? Inicia sesión"
                       FontSize="13"
                       TextColor="#00c9a7"
                       HorizontalTextAlignment="Center"
                       Margin="0,4,0,0">
					<Label.GestureRecognizers>
						<TapGestureRecognizer Tapped="OnLoginClicked"/>
					</Label.GestureRecognizers>
				</Label>

			</VerticalStackLayout>
		</ScrollView>

	</Grid>
</ContentPage>
