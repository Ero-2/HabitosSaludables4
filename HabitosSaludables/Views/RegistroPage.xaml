<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.RegistroPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f0f6ff">

    <Grid RowDefinitions="Auto,*">

        <!-- Header con gradientes -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0a1f3d" Offset="0.0"/>
                    <GradientStop Color="#1a3f7a" Offset="0.6"/>
                    <GradientStop Color="#0d2a5e" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Elementos decorativos -->
            <BoxView WidthRequest="170" HeightRequest="170"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Rotation="20" CornerRadius="32"
                     Margin="0,-60,-40,0" Opacity="0.5">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1e4a8a" Offset="0.0"/>
                        <GradientStop Color="#2e6abf" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <Ellipse WidthRequest="80" HeightRequest="80"
                     HorizontalOptions="Start" VerticalOptions="End"
                     Margin="10,0,0,10" Opacity="0.3">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4a9eff" Offset="0.0"/>
                        <GradientStop Color="#1a4abf" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Contenido del header -->
            <VerticalStackLayout Padding="24,40,24,24" Spacing="12">

                <!-- Botón regresar -->
                <Border StrokeThickness="1" Stroke="#1e4a8a"
                        WidthRequest="40" HeightRequest="40"
                        HorizontalOptions="Start" Margin="0,0,0,4">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0f2a54" Offset="0.0"/>
                            <GradientStop Color="#1a3f7a" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label Text="&#8249;" FontSize="24" TextColor="#4a9eff"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           Margin="0,-2,0,0"/>
                </Border>

                <!-- 🔥 ICONO GRANDE CENTRAL -->
                <Border StrokeThickness="0" 
                        WidthRequest="120" HeightRequest="120"
                        HorizontalOptions="Center"
                        Margin="0,8,0,16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="30"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1e4a8a" Offset="0.0"/>
                            <GradientStop Color="#4a9eff" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label Text="💧" 
                           FontSize="64" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"
                           Margin="0,6,0,0"/>
                </Border>

                <!-- Logo compacto -->
                <Border StrokeThickness="0" HorizontalOptions="Center" Padding="12,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0f2a54" Offset="0.0"/>
                            <GradientStop Color="#1a3f7a" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="✨" FontSize="14" VerticalOptions="Center"/>
                        <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                            <Label Text="Hábitos Saludables"
                                   FontSize="13" FontAttributes="Bold" TextColor="#4a9eff"/>
                            <Label Text="Tu bienestar diario"
                                   FontSize="10" TextColor="#5a8aba"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Label Text="Crea tu cuenta"
                       FontSize="32" FontAttributes="Bold"
                       TextColor="#ffffff" CharacterSpacing="-0.3"
                       HorizontalTextAlignment="Center"
                       Margin="0,8,0,0"/>

                <Label Text="Gratis · Rápido · Sin complicaciones"
                       FontSize="13" TextColor="#6a9ac4"
                       HorizontalTextAlignment="Center"/>

            </VerticalStackLayout>
        </Grid>

        <!-- Formulario de registro -->
        <ScrollView Grid.Row="1" BackgroundColor="#f0f6ff">
            <VerticalStackLayout Padding="24,24,24,40" Spacing="18">

                <!-- Nombre -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="NOMBRE COMPLETO"
                           FontSize="10" TextColor="#7a9abe"
                           CharacterSpacing="1.8" FontAttributes="Bold"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#b8d0f0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry x:Name="nombreEntry"
                               Placeholder="Ej. Carlos García"
                               Text="{Binding Nombre}"
                               PlaceholderColor="#a8c4e8" TextColor="#0a1f3d"
                               FontSize="14" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Email -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="CORREO ELECTRÓNICO"
                           FontSize="10" TextColor="#7a9abe"
                           CharacterSpacing="1.8" FontAttributes="Bold"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#b8d0f0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry x:Name="emailEntry"
                               Placeholder="tu@correo.com" Keyboard="Email"
                               Text="{Binding Email}"
                               PlaceholderColor="#a8c4e8" TextColor="#0a1f3d"
                               FontSize="14" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Contraseña -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="CONTRASEÑA"
                           FontSize="10" TextColor="#7a9abe"
                           CharacterSpacing="1.8" FontAttributes="Bold"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#b8d0f0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry x:Name="contrasenaEntry"
                               Placeholder="Mínimo 8 caracteres"
                               IsPassword="True" Text="{Binding Contrasena}"
                               PlaceholderColor="#a8c4e8" TextColor="#0a1f3d"
                               FontSize="14" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Info de seguridad con icono 🔒 -->
                <Border StrokeThickness="0" Padding="16,12" HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#dce8ff" Offset="0.0"/>
                            <GradientStop Color="#c8d8ff" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <!-- 🔥 ICONO DE SEGURIDAD GRANDE -->
                        <Label Text="🔒" FontSize="28" VerticalOptions="Center"/>
                        <Label Text="Tu información está segura y nunca será compartida."
                               FontSize="12" TextColor="#1a3a7a"
                               VerticalOptions="Center" LineHeight="1.4"
                               WidthRequest="220"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Botón Registrar -->
                <Border StrokeThickness="0" HeightRequest="58" Margin="0,8,0,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1a4abf" Offset="0.0"/>
                            <GradientStop Color="#2e6aef" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Button Text="Crear cuenta"
                            x:Name="RegistrarBtn"
                            Clicked="OnRegisterClicked"
                            BackgroundColor="Transparent"
                            TextColor="#ffffff"
                            FontSize="16" FontAttributes="Bold"/>
                </Border>

                <!-- Link a Login -->
                <Label x:Name="LoginBtn" FontSize="14" HorizontalTextAlignment="Center" Margin="0,4,0,0">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="¿Ya tienes cuenta? " TextColor="#7a9abe" FontSize="14"/>
                            <Span Text="Inicia sesión" TextColor="#0a1f3d" FontSize="14" FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLoginClicked"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>