<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HabitosSaludables.Views.AgregarHabitoPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#f0f6ff">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0a1f3d" Offset="0.0"/>
                    <GradientStop Color="#1a3f7a" Offset="0.6"/>
                    <GradientStop Color="#0f2a54" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <BoxView WidthRequest="130" HeightRequest="130"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Rotation="30" CornerRadius="30"
                     Margin="0,-40,-30,0" Opacity="0.5">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1e4a8a" Offset="0.0"/>
                        <GradientStop Color="#2e6abf" Offset="1.0"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <Grid Padding="22,54,22,28" ColumnDefinitions="Auto,*">

                <Border Grid.Column="0"
                        StrokeThickness="1" Stroke="#1e4a8a"
                        WidthRequest="36" HeightRequest="36"
                        VerticalOptions="Center" Margin="0,0,12,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0f2a54" Offset="0.0"/>
                            <GradientStop Color="#1a3f7a" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label Text="&#8249;" FontSize="20" TextColor="#4a9eff"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="NUEVO HÁBITO"
                           FontSize="9" TextColor="#4a9eff"
                           CharacterSpacing="2" FontAttributes="Bold"/>
                    <Label Text="Personaliza tu rutina"
                           FontSize="22" FontAttributes="Bold" TextColor="#ffffff"
                           CharacterSpacing="-0.3"/>
                </VerticalStackLayout>

            </Grid>
        </Grid>

        <ScrollView Grid.Row="1" BackgroundColor="#f0f6ff">
            <VerticalStackLayout Padding="20,24,20,40" Spacing="20">

                <!-- Nombre -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="NOMBRE DEL HÁBITO"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#7a9abe" CharacterSpacing="1.8"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#b8d0f0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry Placeholder="Ej. Beber 2 litros de agua"
                               Text="{Binding Nombre}"
                               PlaceholderColor="#a8c4e8" TextColor="#0a1f3d"
                               FontSize="14" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Categoría -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="CATEGORÍA"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#7a9abe" CharacterSpacing="1.8"/>
                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#b8d0f0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Picker Title="Selecciona una categoría"
                                ItemsSource="{Binding Categorias}"
                                SelectedItem="{Binding Categoria}"
                                TitleColor="#a8c4e8" TextColor="#0a1f3d"
                                BackgroundColor="Transparent"
                                FontSize="14" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Frecuencia chips -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="FRECUENCIA"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#7a9abe" CharacterSpacing="1.8"/>
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeThickness="0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1a4abf" Offset="0.0"/>
                                    <GradientStop Color="#2e6aef" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="Diario" FontSize="12" FontAttributes="Bold" TextColor="#ffffff"/>
                        </Border>
                        <Border BackgroundColor="#ffffff" StrokeThickness="1.5" Stroke="#b8d0f0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="Semanal" FontSize="12" TextColor="#5a8aba"/>
                        </Border>
                        <Border BackgroundColor="#ffffff" StrokeThickness="1.5" Stroke="#b8d0f0" Padding="14,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="Personalizado" FontSize="12" TextColor="#5a8aba"/>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Ícono -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="ÍCONO (EMOJI)"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="#7a9abe" CharacterSpacing="1.8"/>
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#dce8ff" Offset="0.0"/>
                                    <GradientStop Color="#c8d8ff" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="&#128167;" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#dce8ff" Offset="0.0"/>
                                    <GradientStop Color="#c8d8ff" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="&#127939;" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#dce8ff" Offset="0.0"/>
                                    <GradientStop Color="#c8d8ff" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="&#128564;" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#dce8ff" Offset="0.0"/>
                                    <GradientStop Color="#c8d8ff" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="&#129488;" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#dce8ff" Offset="0.0"/>
                                    <GradientStop Color="#c8d8ff" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="&#128218;" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border StrokeThickness="0" WidthRequest="46" HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#dce8ff" Offset="0.0"/>
                                    <GradientStop Color="#c8d8ff" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="&#129361;" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </HorizontalStackLayout>

                    <Border BackgroundColor="#ffffff"
                            StrokeThickness="1.5" Stroke="#b8d0f0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Entry Placeholder="O escribe tu emoji aquí"
                               Text="{Binding Icono}" MaxLength="2"
                               PlaceholderColor="#a8c4e8" TextColor="#0a1f3d"
                               FontSize="20" BackgroundColor="Transparent" Margin="8,0"/>
                    </Border>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Margin="0,4">
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#c8d8ff" Offset="0.0"/>
                            <GradientStop Color="#dce8ff" Offset="1.0"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Botones -->
                <Grid ColumnDefinitions="*,2*" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            StrokeThickness="1.5" Stroke="#b8d0f0"
                            BackgroundColor="#ffffff" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Button Text="Cancelar"
                                Command="{Binding CancelarCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#2a5aaa"
                                FontSize="13" FontAttributes="Bold"/>
                    </Border>

                    <Border Grid.Column="1" StrokeThickness="0" HeightRequest="54">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1a4abf" Offset="0.0"/>
                                <GradientStop Color="#2e6aef" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Button Text="Guardar hábito"
                                Command="{Binding GuardarHabitoCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#ffffff"
                                FontSize="14" FontAttributes="Bold"/>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>